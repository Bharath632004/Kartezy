# =============================================================================
# Kartezy Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values before running docker-compose
# =============================================================================

# --- Database ---
POSTGRES_PASSWORD=change_me
MONGODB_PASSWORD=change_me
RABBITMQ_PASSWORD=change_me
ELASTICSEARCH_PASSWORD=change_me

# --- JWT ---
JWT_SECRET=base64-encoded-256bit-secret-key-min-32-chars-long
JWT_EXPIRATION=86400000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# --- OAuth / Social Login (optional for local dev) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# --- Mail (optional for local dev) ---
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
