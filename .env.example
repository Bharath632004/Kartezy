# =============================================================================
# Kartezy Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values before running docker-compose
# cp .env.example .env
# =============================================================================

# =====================
# General
# =====================
ENVIRONMENT=development
LOG_LEVEL=debug

# =====================
# API / Gateway
# =====================
API_BASE_URL=http://localhost:8080/api
API_GATEWAY_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# =====================
# PostgreSQL Database
# =====================
POSTGRES_DB=kartezy
POSTGRES_USER=kartezy
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# =====================
# MongoDB
# =====================
MONGODB_DB=kartezy
MONGODB_USER=kartezy
MONGODB_PASSWORD=change_me_in_production
MONGODB_PORT=27017

# =====================
# Redis Cache
# =====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =====================
# RabbitMQ
# =====================
RABBITMQ_USER=kartezy
RABBITMQ_PASSWORD=change_me_in_production
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# =====================
# Apache Kafka
# =====================
KAFKA_PORT=9092
KAFKA_CTRL_PORT=9093
KAFKA_CLUSTER_ID=kartezy-cluster

# =====================
# Elasticsearch
# =====================
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INTERNAL_PORT=9300
ELASTICSEARCH_PASSWORD=change_me_in_production

# =====================
# JWT Authentication
# =====================
JWT_SECRET=generate_a_256bit_base64_secret
JWT_EXPIRATION=86400000
JWT_REFRESH_TOKEN_EXPIRATION=604800000
JWT_ISSUER_URI=http://auth-service:8080
JWK_SET_URI=http://auth-service:8080/oauth2/jwks

# =====================
# OAuth2 Providers
# =====================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# =====================
# Email (SMTP)
# =====================
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# =====================
# Firebase
# =====================
FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_PROJECT_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_STORAGE_BUCKET=

# =====================
# AI Platform
# =====================
AI_MODEL_PATH=/models
ENCRYPTION_KEY=generate_a_256bit_key_here
REDIS_URL=redis://localhost:6379

# =====================
# Payment Gateway (Razorpay)
# =====================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# =====================
# SMS Gateway
# =====================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# =====================
# Push Notifications
# =====================
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=

# =====================
# Storage / CDN
# =====================
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=kartezy-media
CDN_URL=

# =====================
# Monitoring
# =====================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=

# =====================
# Infrastructure
# =====================
SPRING_PROFILES=prod
NGINX_HOST=localhost
NGINX_PORT=80
NGINX_SSL_PORT=443
DISCOVERY_SERVER_PORT=8761
CONFIG_SERVER_PORT=8888

# =====================
# Service Ports (Backend)
# =====================
AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
MERCHANT_SERVICE_PORT=8083
CATALOG_SERVICE_PORT=8084
INVENTORY_SERVICE_PORT=8085
ORDER_SERVICE_PORT=8086
PAYMENT_SERVICE_PORT=8087
DELIVERY_SERVICE_PORT=8088
NOTIFICATION_SERVICE_PORT=8089
WALLET_SERVICE_PORT=8090
REVIEW_SERVICE_PORT=8091
RECOMMENDATION_SERVICE_PORT=8092
ANALYTICS_SERVICE_PORT=8093
AI_SERVICE_PORT=8094
FORECASTING_SERVICE_PORT=8095
CHATBOT_SERVICE_PORT=8096
CV_SERVICE_PORT=8097
NLP_SERVICE_PORT=8098
OCR_SERVICE_PORT=8099
VOICE_SERVICE_PORT=8100
FRAUD_SERVICE_PORT=8101
FINANCE_SERVICE_PORT=8102
CMS_SERVICE_PORT=8103
SEARCH_SERVICE_PORT=8104
SUPPORT_SERVICE_PORT=8105
