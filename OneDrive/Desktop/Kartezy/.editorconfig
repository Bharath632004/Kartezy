root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.md]
max_line_length = off
trim_trailing_whitespace = false

[*.{js,jsx,ts,tsx,css,scss,html,json,yml,yaml,md,vue,graphql,gql}]
indent_size = 2
indent_style = space

[*.{java,kt,kts,kts,scala,sc,scala,rb,py,go,rs,cs,fs,fsx,swift,dart}]
indent_size = 4
indent_style = space

[Makefile]
indent_style = tab

[*.txt]
max_line_length = off