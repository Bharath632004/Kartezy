# Finance Service Environment Configuration
# Copy to .env and fill in actual values

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kartezy_finance
DB_USERNAME=kartezy
DB_PASSWORD=kartezy123

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Eureka
EUREKA_URI=http://localhost:8761/eureka

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT / OAuth2
JWT_ISSUER_URI=http://localhost:8081/realms/kartezy
JWT_JWK_URI=http://localhost:8081/realms/kartezy/protocol/openid-connect/certs

# Logging
LOG_LEVEL=INFO

# Service Ports
FINANCE_SERVICE_PORT=8096

# Encryption (change in production!)
ENCRYPTION_SECRET_KEY=change-me-in-production-kartezy-finance-32char
ENCRYPTION_IV=change-me-16char
