<?xml version="1.0" encoding="UTF-8"?>
<!-- ============================================================
     Kartezy SpotBugs Security Include Filters
     Identifies security-relevant bug patterns
     ============================================================ -->
<FindBugsFilter>
    <!-- SQL Injection -->
    <Match>
        <Bug category="SQL" />
    </Match>

    <!-- Cross-Site Scripting (XSS) -->
    <Match>
        <Bug pattern="XSS" />
    </Match>

    <!-- Command Injection -->
    <Match>
        <Bug pattern="COMMAND_INJECTION" />
    </Match>

    <!-- Path Traversal -->
    <Match>
        <Bug pattern="PATH_TRAVERSAL_IN" />
    </Match>

    <!-- Insecure Configuration -->
    <Match>
        <Bug pattern="INSECURE_CONFIGURATION" />
    </Match>

    <!-- CRLF Injection -->
    <Match>
        <Bug pattern="CRLF_INJECTION" />
    </Match>

    <!-- Weak Message Digest -->
    <Match>
        <Bug pattern="WEAK_MESSAGE_DIGEST" />
    </Match>

    <!-- Hardcoded Credentials -->
    <Match>
        <Bug pattern="HARDCODED_CREDENTIALS" />
    </Match>

    <!-- Seamans HTTP Parameter -->
    <Match>
        <Bug pattern="HTTP_PARAMETER_POLLUTION" />
    </Match>

    <!-- Weak Cryptography -->
    <Match>
        <Bug category="SECURITY">
            <Bug code="WEAK_CRYPTOGRAPHY" />
        </Bug>
    </Match>

    <!-- All SECURITY category bugs -->
    <Match>
        <Bug category="SECURITY" />
    </Match>

    <!-- Malicious Code - Use of untrusted input -->
    <Match>
        <Bug category="MALICIOUS_CODE" />
    </Match>

    <!-- Bad Practice - Security relevant -->
    <Match>
        <Bug category="BAD_PRACTICE">
            <Bug pattern="DM_DEFAULT_ENCODING" />
            <Bug pattern="DMI_HARDCODED_ABSOLUTE_FILENAME" />
            <Bug pattern="DMI_UNSUPPORTED_ENCODING" />
        </Bug>
    </Match>
</FindBugsFilter>
